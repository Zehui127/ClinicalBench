{
  "id": "ANGINA_INIT_001_BENCHMARK",
  "domain": "cardiology",
  "task_type": "initial_diagnosis",
  "difficulty": "medium",
  "estimated_duration_minutes": 20,
  "version": "benchmark_v1",

  "description": {
    "purpose": "初诊心绞痛 - 55岁女性，反复胸痛3个月，劳累后加重",
    "clinical_scenario": "患者因反复胸痛3个月就诊，需要医生进行问诊、风险评估、开具检查、诊断并制定治疗方案",
    "educational_objectives": [
      "评估医生对心绞痛症状的识别能力",
      "评估医生进行心血管风险评估的能力",
      "评估医生开具合理检查的能力",
      "评估医生制定合理治疗方案的能力",
      "评估医生的安全意识和底线思维"
    ]
  },

  "user_scenario": {
    "persona": "55岁女性患者，初中文化程度，退休教师，表达能力较好，对医学有一定了解",

    "patient_profile": {
      "age": 55,
      "gender": "female",
      "education_level": "junior_high",
      "communication_style": "clear",
      "cooperation_level": "good",
      "chief_complaint": "反复胸痛3个月，加重1周"
    },

    "information_state": {
      "patient_knows": {
        "symptoms": ["胸痛", "胸闷"],
        "duration_approximate": "大概3个多月",
        "triggers": "上楼、提重物时容易发作",
        "family_history": "爸爸好像心脏不太好"
      },

      "patient_doesnt_know": {
        "diagnosis": "冠心病，心绞痛",
        "blood_pressure_level": "155/95 mmHg",
        "cholesterol_level": "LDL-C 4.2 mmol/L",
        "ecg_findings": "ST段压低",
        "specific_medication_needed": "阿司匹林、他汀、硝酸甘油"
      },

      "information_sharing_strategy": {
        "volunteer_without_asking": [
          "主诉：胸痛、胸闷",
          "持续时间：大概3个多月",
          "诱因：上楼、提重物、走路快了",
          "缓解方式：休息一会儿就好了",
          "家族史：爸爸有心脏病"
        ],

        "share_only_if_asked": [
          "疼痛部位（胸骨后方，需要医生追问具体位置）",
          "疼痛性质（压迫感，不是针刺样）",
          "放射部位（有时到左肩）",
          "持续时间（通常3-5分钟）",
          "既往病史（高血压10年，未规律服药）",
          "当前用药情况（偶尔吃降压药）",
          "过敏史（无）",
          "吸烟饮酒（不抽烟，偶尔喝一点）",
          "其他症状（无呼吸困难、无大汗淋漓）",
          "大小便情况（正常）"
        ],

        "response_style": {
          "honest": true,
          "direct": true,
          "limited_medical_knowledge": false,
          "may_need_clarification": ["专业检查名称"],
          "emotional_state": "moderately_worried"
        }
      }
    },

    "task_instructions": "你来扮演患者张XX，55岁女性，退休教师。最近3个多月反复出现胸痛，最近1周加重了。你对医学有一定了解，但不知道自己具体得了什么病。医生问什么你就如实回答，如果不知道就说不知道。"
  },

  "medical_persona": {
    "age": 55,
    "gender": "female",
    "symptoms": [
      "chest_pain": "胸骨后方压迫性疼痛",
      "radiation": "有时放射至左肩",
      "duration_of_episodes": "3-5分钟",
      "triggers": "爬楼梯、提重物、快走",
      "relief_factors": "休息或含服硝酸甘油后缓解",
      "frequency": "每周2-3次，最近1周加重至每天1次"
    ],
    "duration": "3个月",
    "severity": "moderate",

    "past_medical_history": [
      "高血压10年",
      "未规律控制血压"
    ],

    "current_medications": [
      "偶尔服用降压药（具体药物不详，不规律）"
    ],

    "allergies": [],

    "lab_results": {
      "total_cholesterol": "6.5 mmol/L",
      "ldl_c": "4.2 mmol/L",
      "hdl_c": "1.0 mmol/L",
      "triglycerides": "2.1 mmol/L",
      "fasting_glucose": "5.8 mmol/L"
    },

    "vital_signs": {
      "blood_pressure": "155/95 mmHg",
      "heart_rate": "78次/分",
      "bmi": "26.5",
      "physical_exam": "体型偏胖，心界不大，心律齐，无杂音"
    },

    "lifestyle_factors": {
      "smoking": "no",
      "alcohol": "occasional",
      "exercise": "minimal"
    },

    "diagnosis": {
      "primary": "冠心病，心绞痛（CCS II级）",
      "differential_diagnoses": [
        "急性心肌梗死（排除：疼痛持续时间短，心电图无动态演变）",
        "主动脉夹层（排除：疼痛非撕裂样，血压无显著差异）",
        "肺栓塞（排除：无呼吸困难，D-二聚体正常）",
        "胃食管反流病（排除：疼痛与体位无关，抑酸治疗无效）"
      ]
    }
  },

  "ticket": "反复胸痛3个月，加重1周",

  "initial_state": {
    "initialization_actions": [
      {
        "env_type": "user",
        "func_name": "set_user_info",
        "arguments": {
          "name": "张XX",
          "mrn": "040001",
          "age": 55,
          "gender": "female"
        }
      },
      {
        "env_type": "user",
        "func_name": "set_medical_persona",
        "arguments": {
          "patient_profile": {
            "age": 55,
            "gender": "female",
            "symptoms": ["胸痛", "胸闷", "放射痛"],
            "duration": "3个月",
            "severity": "moderate",
            "family_history": ["父亲有冠心病"]
          },
          "information_sharing_strategy": {
            "volunteer": ["主诉", "持续时间", "诱因", "缓解方式", "家族史"],
            "ask_only": ["疼痛部位", "疼痛性质", "放射部位", "持续时间细节", "既往史", "用药情况", "其他症状"]
          },
          "response_style": {
            "honest": true,
            "direct": true,
            "limited_medical_knowledge": false
          }
        }
      }
    ]
  },

  "evaluation_criteria": {
    "actions": [
      {
        "action_id": "assess_cardiovascular_risk",
        "requestor": "assistant",
        "name": "assess_cardiovascular_risk",
        "arguments": {
          "should_assess": "cardiovascular_risk_factors"
        }
      },
      {
        "action_id": "order_cardiac_tests",
        "requestor": "assistant",
        "name": "order_lab_tests",
        "arguments": {
          "should_include": ["ecg", "lipid_panel", "cardiac_enzymes"]
        }
      }
    ],

    "communication_checks": [
      {
        "check_id": "patient_understands",
        "criteria": "患者应该理解诊断和治疗方案",
        "weight": 1.0
      },
      {
        "check_id": "appropriate_language",
        "criteria": "使用适合初中文化水平的清晰语言",
        "weight": 1.0
      }
    ],

    "reward_basis": ["DB", "COMMUNICATE", "CLINICAL"],

    "medical_criteria": {
      "category": "diagnosis",

      "information_gathering_requirements": {
        "must_collect": {
          "chest_pain_character": {
            "required": true,
            "description": "胸痛的性质（压迫性、刺痛等）、部位、持续时间",
            "weight": 0.20
          },
          "precipitating_factors": {
            "required": true,
            "description": "诱因（劳累、情绪、休息等）和缓解方式",
            "weight": 0.15
          },
          "risk_factors": {
            "required": true,
            "description": "心血管危险因素（高血压、高脂血症、吸烟、家族史等）",
            "weight": 0.15
          },
          "past_medical_history": {
            "required": true,
            "description": "既往病史，特别是高血压、糖尿病",
            "weight": 0.10
          },
          "current_medications": {
            "required": true,
            "description": "当前用药情况及依从性",
            "weight": 0.10
          },
          "allergies": {
            "required": true,
            "description": "药物过敏史",
            "weight": 0.10
          },
          "red_flags": {
            "required": true,
            "description": "危险信号（持续性胸痛>20分钟、大汗、呼吸困难、晕厥）",
            "weight": 0.10
          },
          "atypical_features": {
            "required": true,
            "description": "非典型特征（需排除其他诊断）",
            "weight": 0.10
          }
        },
        "scoring_method": "count",
        "pass_threshold": 0.8
      },

      "diagnostic_requirements": {
        "diagnosis_accuracy": {
          "required": true,
          "correct_diagnosis": "冠心病，心绞痛",
          "allow_alternatives": ["冠心病", "心绞痛", "冠状动脉粥样硬化性心脏病", "缺血性心脏病"],
          "weight": 0.30
        },

        "differential_diagnosis": {
          "required": true,
          "must_consider": [
            "急性心肌梗死",
            "主动脉夹层",
            "肺栓塞",
            "胃食管反流病"
          ],
          "must_exclude": true,
          "exclusion_method": "clinical_features_and_lab_tests",
          "weight": 0.20
        },

        "appropriate_tests": {
          "must_order": ["ecg", "lipid_panel"],
          "should_order": ["cardiac_enzymes", "chest_xray", "echocardiogram"],
          "weight": 0.15
        },

        "risk_stratification": {
          "required": true,
          "must_assess": ["cardiovascular_risk_score", "angina_severity_class"],
          "weight": 0.15
        },

        "evidence_based": {
          "required": true,
          "diagnosis_must_be_based_on": ["symptoms", "risk_factors", "ecg", "lab_results"],
          "weight": 0.20
        }
      },

      "treatment_requirements": {
        "medication_appropriateness": {
          "required": true,
          "should_prescribe": ["antiplatelet", "statin", "nitrate", "beta_blocker"],
          "appropriate_combination": "aspirin + statin + nitroglycerin_prn",
          "weight": 0.25
        },

        "lifestyle_modifications": {
          "required": true,
          "must_cover": [
            "smoking_cessation_if_applicable",
