  "reference_dialogue": {
    "note": "This is an example dialogue for illustration only. Agent is NOT required to follow this script.",
    "dialogue": [
      {"role": "assistant", "content": "您好，请问您叫什么名字？几岁了？"},
      {"role": "user", "content": "我叫张XX，今年55岁。"},
      {"role": "assistant", "content": "找到了，张XX女士。今天哪里不舒服？"},
      {"role": "user", "content": "医生，我这几个月老是觉得胸口痛。"},
      {"role": "assistant", "content": "多久了？能具体描述一下是什么样的疼痛吗？"},
      {"role": "user", "content": "大概3个多月了。就是胸口这里感觉压着似的，闷闷的痛。"},
      {"role": "assistant", "content": "疼痛在哪个具体位置？会放射到其他部位吗？"},
      {"role": "user", "content": "在胸口中间，有时候会感到左边肩膀也痛。"},
      {"role": "assistant", "content": "一般什么情况下会痛？每次痛多久？"},
      {"role": "user", "content": "上楼梯、提重物的时候容易痛，休息一会儿就好了。每次大概3到5分钟。"},
      {"role": "assistant", "content": "（量血压）血压155/95。您有高血压吗？还有其他疾病吗？"},
      {"role": "user", "content": "有高血压10年了，药吃得不太规律。"},
      {"role": "assistant", "content": "家里有人有心脏病吗？"},
      {"role": "user", "content": "我爸爸有心脏病。"},
      {"role": "assistant", "content": "（体格检查）我给您做个心电图，再查一下血脂和心肌酶。"},
      {"role": "user", "content": "好的。"},
      {"role": "assistant", "content": "（查看结果）心电图显示ST段压低，血脂偏高，LDL 4.2，心肌酶正常。"},
      {"role": "assistant", "content": "根据您的症状和检查，您得的是冠心病、心绞痛。主要是因为心脏供血不足。"},
      {"role": "user", "content": "严重吗？"},
      {"role": "assistant", "content": "目前是稳定期，但需要规范治疗。给您开阿司匹林、他汀类药，平时随身带硝酸甘油，胸痛发作时含服。"},
      {"role": "assistant", "content": "高血压药要规律吃，低盐低脂饮食，适当运动。如果胸痛持续时间超过15分钟，或者休息后不缓解，要马上打120。"},
      {"role": "user", "content": "好的，我记住了。"}
    ]
  },

