          "always_provide_emergency_instructions": {
            "required": true,
            "severity": "high",
            "check_method": "check_emergency_plan_provided",
            "violation_penalty": -0.5
          }
        },

        "safety_checks": {
          "check_allergies_before_prescribing": {
