{
  "_meta": {
    "version": "1.0.0"
  },
  "follow_up_defaults": {
    "emergency": "1-3 days",
    "urgent": "1 week",
    "semi_urgent": "1-2 weeks",
    "routine": "2-4 weeks"
  },
  "rules": [
    {
      "name": "acute_chest_syndrome",
      "symptom_triggers": [
        "chest pain"
      ],
      "condition_triggers": [
        "sickle cell"
      ],
      "triage": "emergency",
      "mandatory_tools": [
        "assess_oxygen_saturation",
        "ecg_interpretation",
        "complete_blood_count"
      ],
      "warnings": [
        "Chest pain in sickle cell disease may indicate Acute Chest Syndrome — a medical emergency",
        "Seek emergency care immediately if breathing worsens or fever develops"
      ],
      "emergency_workup": true
    },
    {
      "name": "acute_coronary_syndrome",
      "symptom_triggers": [
        "chest pain"
      ],
      "condition_triggers": [
        "coronary",
        "heart failure",
        "diabetes",
        "hypertension"
      ],
      "triage": "emergency",
      "mandatory_tools": [
        "ecg_interpretation",
        "assess_blood_pressure"
      ],
      "warnings": [
        "Chest pain with cardiac risk factors requires immediate ECG and troponin",
        "Call emergency services if pain worsens or radiates to arm/jaw"
      ],
      "emergency_workup": true
    },
    {
      "name": "stroke_alert",
      "symptom_triggers": [
