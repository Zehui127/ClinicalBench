      "returns": "patient_response: string",
      "effect": "turn_count += 1; may reveal if_asked/hidden symptoms"
    },
    "ORDER_LAB": {
      "params": {
        "tests": "list[string]"
      },
      "returns": "order_id: string",
      "effect": "labs_ordered[tests] = true",
