        "creatinine",
        "sodium",
        "platelet_count",
        "inr"
      ]
    },
    "GET_RESULTS": {
      "params": {
        "order_id": "string"
      },
      "returns": "results: dict[test_name, value_string]",
      "precondition": "ORDER_LAB executed first"
    },
    "DIAGNOSE": {
      "params": {
        "diagnosis": "string",
        "confidence": "float 0-1"
      },
      "returns": "recorded: boolean"
    },
    "CHECK_ALLERGY": {
      "params": {},
